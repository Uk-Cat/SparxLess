{
  "manifest_version": 3,
  "name": "SparxLess",
  "icons": {
   "16": "Icon/Sparx_Math_Logo_16.png",
   "32": "Icon/Sparx_Math_Logo_32.png",
   "48": "Icon/Sparx_Math_Logo_48.png",
   "128": "Icon/Sparx_Math_Logo_128.png"
 },
  "version": "1.3.0",
  "description": "An extension to help complete your sparx math homework. Answers are automatically saved for bookwork checks and can be submitted to a shared database.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://maths.sparx-learning.com/*",
    "https://uxcwmzmktamtlyvwzsua.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.sparx-learning.com/*"],
      "js": ["content.js"]
    }
  ]
}