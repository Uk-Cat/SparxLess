{
  "manifest_version": 3,
  "name": "Sparx Maths Helper",
  "version": "1.2.0",
  "description": "Automatically saves Sparx Maths questions to the Unconfirmed table on answer submission.",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://*.sparxmaths.uk/*",
    "https://*.sparxmaths.com/*",
    "https://*.sparx-learning.com/*",
    "https://uxcwmzmktamtlyvwzsua.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Sparx Helper"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.sparxmaths.uk/*",
        "https://*.sparxmaths.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}