{
  "manifest_version": 3,
  "name": "SparxLess",
  "version": "1.2.0",
  "description": "An extension to help complete your Sparx maths homework.",

  "permissions": ["activeTab", "scripting", "storage", "tabs"],

  "host_permissions": [
    "https://*.sparxmaths.uk/*",
    "https://*.sparxmaths.com/*",
    "https://*.sparx-learning.com/*",
    "https://maths.sparx-learning.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://uxcwmzmktamtlyvwzsua.supabase.co/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.sparxmaths.uk/*",
        "https://*.sparxmaths.com/*",
        "https://*.sparx-learning.com/*",
        "https://maths.sparx-learning.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}